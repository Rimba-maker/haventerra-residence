---
// Haventerra Residence — Landing Page
// Design: Airbnb compositional DNA × Forest Sage palette × DM Serif Display hero
---
<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Haventerra Residence — Perumahan Premium Tangerang Selatan</title>
  <meta name="description" content="Hunian premium 250 unit dalam 12 hektar lahan hijau di Tangerang Selatan. 15 menit dari MRT, fasilitas lengkap, KPR 9 bank partner. Mulai Rp 850 jt." />
  <meta property="og:title" content="Haventerra Residence — Rumah Impian, Tempat Cerita Bermula" />
  <meta property="og:description" content="Hunian premium eco-living di Tangerang Selatan. 250 unit, 12 hektar lahan hijau." />
  <meta property="og:type" content="website" />

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap" rel="stylesheet" />

  <style is:global>
    /* ─── HAVENTERRA DESIGN TOKENS ───────────────────────────────────────────
       DNA: Airbnb (photo-first, trust signals, soft rounding, white canvas)
       Adaptation: Forest Sage primary, warm cream alternates, DM Serif hero
    ──────────────────────────────────────────────────────────────────────── */
    :root {
      --color-primary:        #3d6b52;
      --color-primary-hover:  #2d5340;
      --color-primary-light:  #d4e8db;
      --color-accent:         #c8763a;
      --color-accent-light:   #fdf0e6;
      --color-canvas:         #ffffff;
      --color-warm-cream:     #faf8f4;
      --color-surface-soft:   #f2efe9;
      --color-ink:            #1a1a1a;
      --color-body:           #3d3d3d;
      --color-muted:          #6a6a6a;
      --color-hairline:       #e0dbd4;
      --color-dark-band:      #1e3428;

      --font-display: 'DM Serif Display', Georgia, serif;
      --font-body:    'Plus Jakarta Sans', -apple-system, system-ui, sans-serif;

      --rounded-xs:   4px;
      --rounded-sm:   8px;
      --rounded-md:   14px;
      --rounded-lg:   20px;
      --rounded-xl:   32px;
      --rounded-full: 9999px;

      --shadow-card:       rgba(0,0,0,0.02) 0 0 0 1px, rgba(0,0,0,0.04) 0 2px 8px, rgba(0,0,0,0.06) 0 4px 16px;
      --shadow-card-hover: rgba(0,0,0,0.02) 0 0 0 1px, rgba(0,0,0,0.08) 0 6px 20px, rgba(0,0,0,0.10) 0 12px 32px;

      --section-py:     88px;
      --container-max:  1280px;
      --container-px:   80px;
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; }
    body {
      font-family: var(--font-body);
      background: var(--color-canvas);
      color: var(--color-body);
      font-size: 16px;
      line-height: 1.5;
      -webkit-font-smoothing: antialiased;
    }
    img { display: block; max-width: 100%; }
    a { text-decoration: none; color: inherit; }
    ul { list-style: none; }

    .container {
      max-width: var(--container-max);
      margin: 0 auto;
      padding-left: var(--container-px);
      padding-right: var(--container-px);
    }

    /* ─── BUTTONS ─── */
    .btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      padding: 13px 26px;
      font-family: var(--font-body);
      font-size: 15px;
      font-weight: 600;
      line-height: 1.2;
      border-radius: var(--rounded-sm);
      border: 1.5px solid transparent;
      cursor: pointer;
      transition: all 0.2s ease;
      white-space: nowrap;
    }
    .btn--primary  { background: var(--color-primary); color: #fff; border-color: var(--color-primary); }
    .btn--primary:hover { background: var(--color-primary-hover); border-color: var(--color-primary-hover); }
    .btn--white    { background: #fff; color: var(--color-ink); }
    .btn--white:hover { background: var(--color-surface-soft); }
    .btn--outline  { background: transparent; color: var(--color-ink); border-color: var(--color-ink); }
    .btn--outline:hover { background: var(--color-ink); color: #fff; }
    .btn--outline-primary { background: transparent; color: var(--color-primary); border-color: var(--color-primary); }
    .btn--outline-primary:hover { background: var(--color-primary); color: #fff; }
    .btn--ghost-white {
      background: rgba(255,255,255,0.14);
      color: #fff;
      border-color: rgba(255,255,255,0.45);
      backdrop-filter: blur(6px);
    }
    .btn--ghost-white:hover { background: rgba(255,255,255,0.24); }
    .btn--lg  { padding: 16px 34px; font-size: 16px; }
    .btn--pill { border-radius: var(--rounded-full); }
    .btn--full { width: 100%; justify-content: center; }

    /* ─── SECTION LABEL ─── */
    .section-label {
      display: inline-block;
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--color-primary);
      margin-bottom: 12px;
    }

    /* ══════════════════════════════════════════════════════════════
       01 — NAVBAR
    ══════════════════════════════════════════════════════════════ */
    .navbar {
      position: sticky;
      top: 0;
      z-index: 100;
      background: var(--color-canvas);
      border-bottom: 1px solid var(--color-hairline);
      height: 72px;
      display: flex;
      align-items: center;
    }
    .navbar__inner {
      display: flex;
      align-items: center;
      justify-content: space-between;
      width: 100%;
    }
    .navbar__logo { display: flex; flex-direction: column; line-height: 1; }
    .logo-name {
      font-family: var(--font-display);
      font-size: 21px;
      color: var(--color-ink);
      letter-spacing: -0.3px;
    }
    .logo-tag {
      font-size: 9px;
      font-weight: 700;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--color-primary);
      margin-top: 2px;
    }
    .navbar__links {
      display: flex;
      align-items: center;
      gap: 32px;
    }
    .navbar__links a {
      font-size: 14px;
      font-weight: 500;
      color: var(--color-body);
      transition: color 0.15s ease;
    }
    .navbar__links a:hover { color: var(--color-ink); }

    /* ══════════════════════════════════════════════════════════════
       02 — HERO
    ══════════════════════════════════════════════════════════════ */
    .hero {
      position: relative;
      height: 100svh;
      min-height: 620px;
      display: flex;
      align-items: flex-end;
      overflow: hidden;
    }
    .hero__bg { position: absolute; inset: 0; }
    .hero__bg img { width: 100%; height: 100%; object-fit: cover; object-position: center 65%; }
    .hero__overlay {
      position: absolute;
      inset: 0;
      background: linear-gradient(
        to top,
        rgba(8, 18, 12, 0.88) 0%,
        rgba(8, 18, 12, 0.35) 55%,
        rgba(8, 18, 12, 0.08) 100%
      );
    }
    .hero__content {
      position: relative;
      z-index: 2;
      padding-bottom: 80px;
      width: 100%;
    }
    .hero__eyebrow {
      font-size: 12px;
      font-weight: 600;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: rgba(255,255,255,0.6);
      margin-bottom: 18px;
    }
    .hero__headline {
      font-family: var(--font-display);
      font-size: clamp(42px, 5.5vw, 68px);
      font-weight: 400;
      line-height: 1.1;
      color: #fff;
      margin-bottom: 22px;
      letter-spacing: -0.5px;
      max-width: 680px;
    }
    .hero__headline em { font-style: italic; opacity: 0.92; }
    .hero__sub {
      font-size: 17px;
      font-weight: 400;
      line-height: 1.65;
      color: rgba(255,255,255,0.78);
      max-width: 520px;
      margin-bottom: 36px;
    }
    .hero__ctas {
      display: flex;
      gap: 12px;
      flex-wrap: wrap;
      margin-bottom: 52px;
    }
    .hero__badges { display: flex; gap: 10px; flex-wrap: wrap; }
    .hero__badge {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 7px 14px;
      background: rgba(255,255,255,0.11);
      backdrop-filter: blur(10px);
      border: 1px solid rgba(255,255,255,0.22);
      border-radius: var(--rounded-full);
      font-size: 13px;
      font-weight: 500;
      color: rgba(255,255,255,0.88);
    }

    /* ══════════════════════════════════════════════════════════════
       03 — ABOUT
    ══════════════════════════════════════════════════════════════ */
    .about {
      background: var(--color-warm-cream);
      padding: var(--section-py) 0;
    }
    .about__grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 80px;
      align-items: center;
    }
    .about__photo {
      border-radius: var(--rounded-lg);
      overflow: hidden;
      aspect-ratio: 4/3;
    }
    .about__photo img { width: 100%; height: 100%; object-fit: cover; }
    .about__text h2 {
      font-family: var(--font-display);
      font-size: clamp(32px, 3.2vw, 44px);
      font-weight: 400;
      color: var(--color-ink);
      line-height: 1.18;
      margin-bottom: 20px;
    }
    .about__text p {
      font-size: 16px;
      line-height: 1.8;
      color: var(--color-body);
      margin-bottom: 16px;
    }
    .about__text p:last-of-type { margin-bottom: 32px; }
    .about__pills { display: flex; flex-wrap: wrap; gap: 10px; }
    .about__pill {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 10px 18px;
      background: #fff;
      border: 1px solid var(--color-hairline);
      border-radius: var(--rounded-full);
      font-size: 14px;
      font-weight: 600;
      color: var(--color-ink);
      box-shadow: var(--shadow-card);
    }

    /* ══════════════════════════════════════════════════════════════
       04 — TYPES (Airbnb property-card pattern)
    ══════════════════════════════════════════════════════════════ */
    .types { background: var(--color-canvas); padding: var(--section-py) 0; }
    .section-header {
      text-align: center;
      margin-bottom: 52px;
    }
    .section-header h2 {
      font-family: var(--font-display);
      font-size: clamp(28px, 3vw, 42px);
      font-weight: 400;
      color: var(--color-ink);
      margin-bottom: 10px;
    }
    .section-header p { font-size: 16px; color: var(--color-muted); }
    .types__grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 20px;
    }
    .type-card {
      background: var(--color-canvas);
      border-radius: var(--rounded-md);
      overflow: hidden;
      box-shadow: var(--shadow-card);
      transition: box-shadow 0.3s ease, transform 0.3s ease;
      cursor: pointer;
    }
    .type-card:hover {
      box-shadow: var(--shadow-card-hover);
      transform: translateY(-7px);
    }
    .type-card__photo {
      position: relative;
      aspect-ratio: 4/5;
      overflow: hidden;
    }
    .type-card__photo img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      transition: transform 0.5s ease;
    }
    .type-card:hover .type-card__photo img { transform: scale(1.05); }
    .type-card__badge {
      position: absolute;
      top: 12px;
      left: 12px;
      padding: 5px 11px;
      background: var(--color-accent);
      color: #fff;
      border-radius: var(--rounded-full);
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 0.02em;
    }
    .type-card__save {
      position: absolute;
      top: 10px;
      right: 10px;
      width: 32px;
      height: 32px;
      background: rgba(255,255,255,0.88);
      border-radius: var(--rounded-full);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 15px;
      cursor: pointer;
      transition: transform 0.15s ease, background 0.15s ease;
    }
    .type-card__save:hover { transform: scale(1.12); background: #fff; }
    .type-card__meta { padding: 16px; }
    .type-card__name {
      font-size: 15px;
      font-weight: 600;
      color: var(--color-ink);
      margin-bottom: 5px;
    }
    .type-card__specs {
      font-size: 13px;
      color: var(--color-muted);
      line-height: 1.55;
      margin-bottom: 10px;
    }
    .type-card__price {
      font-size: 16px;
      font-weight: 700;
      color: var(--color-ink);
    }
    .type-card__price-note { font-size: 12px; font-weight: 400; color: var(--color-muted); }
    .type-card__units {
      font-size: 12px;
      color: var(--color-primary);
      font-weight: 600;
      margin-top: 4px;
    }

    /* ══════════════════════════════════════════════════════════════
       05 — MASTER PLAN
    ══════════════════════════════════════════════════════════════ */
    .masterplan { background: var(--color-warm-cream); padding: var(--section-py) 0; }
    .masterplan__visual {
      position: relative;
      border-radius: var(--rounded-lg);
      overflow: hidden;
      aspect-ratio: 16/7;
      margin-top: 0;
    }
    .masterplan__visual img { width: 100%; height: 100%; object-fit: cover; }
    .masterplan__overlay {
      position: absolute;
      inset: 0;
      background: linear-gradient(to top, rgba(8,18,12,0.5) 0%, transparent 60%);
    }
    .masterplan__legend {
      position: absolute;
      bottom: 24px;
      left: 24px;
      display: flex;
      gap: 10px;
      flex-wrap: wrap;
    }
    .legend-item {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 6px 13px;
      background: rgba(255,255,255,0.92);
      backdrop-filter: blur(6px);
      border-radius: var(--rounded-full);
      font-size: 12px;
      font-weight: 600;
      color: var(--color-ink);
    }

    /* ══════════════════════════════════════════════════════════════
       06 — FACILITIES
    ══════════════════════════════════════════════════════════════ */
    .facilities { background: var(--color-canvas); padding: var(--section-py) 0; }
    .facilities__grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 20px;
    }
    .facility-card {
      background: var(--color-canvas);
      border-radius: var(--rounded-md);
      overflow: hidden;
      box-shadow: var(--shadow-card);
      transition: transform 0.25s ease, box-shadow 0.25s ease;
    }
    .facility-card:hover { transform: translateY(-4px); box-shadow: var(--shadow-card-hover); }
    .facility-card__photo { aspect-ratio: 16/9; overflow: hidden; }
    .facility-card__photo img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      transition: transform 0.45s ease;
    }
    .facility-card:hover .facility-card__photo img { transform: scale(1.05); }
    .facility-card__meta { padding: 20px; }
    .facility-card__icon { font-size: 26px; margin-bottom: 10px; }
    .facility-card__title {
      font-size: 16px;
      font-weight: 700;
      color: var(--color-ink);
      margin-bottom: 6px;
    }
    .facility-card__desc { font-size: 14px; color: var(--color-muted); line-height: 1.55; }

    /* ══════════════════════════════════════════════════════════════
       07 — LOCATION
    ══════════════════════════════════════════════════════════════ */
    .location { background: var(--color-warm-cream); padding: var(--section-py) 0; }
    .location__grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 72px;
      align-items: center;
    }
    .location__text h2 {
      font-family: var(--font-display);
      font-size: clamp(28px, 3vw, 42px);
      font-weight: 400;
      color: var(--color-ink);
      margin-bottom: 12px;
    }
    .location__text > p {
      font-size: 16px;
      color: var(--color-muted);
      margin-bottom: 32px;
      line-height: 1.65;
    }
    .location__landmarks { display: flex; flex-direction: column; gap: 8px; }
    .location__landmark {
      display: flex;
      align-items: center;
      gap: 14px;
      padding: 13px 16px;
      background: #fff;
      border-radius: var(--rounded-sm);
      border: 1px solid var(--color-hairline);
      transition: border-color 0.15s ease, background 0.15s ease;
    }
    .location__landmark:hover {
      border-color: var(--color-primary-light);
      background: rgba(212,232,219,0.25);
    }
    .location__landmark-icon { font-size: 18px; flex-shrink: 0; }
    .location__landmark-name { font-size: 14px; font-weight: 500; color: var(--color-ink); flex: 1; }
    .location__landmark-dist {
      font-size: 13px;
      font-weight: 700;
      color: var(--color-primary);
      flex-shrink: 0;
    }
    .location__map {
      border-radius: var(--rounded-lg);
      overflow: hidden;
      aspect-ratio: 1/1;
      position: relative;
    }
    .location__map img { width: 100%; height: 100%; object-fit: cover; }
    .location__map-pin {
      position: absolute;
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%);
      background: var(--color-primary);
      color: #fff;
      padding: 9px 18px;
      border-radius: var(--rounded-full);
      font-size: 13px;
      font-weight: 700;
      white-space: nowrap;
      box-shadow: 0 4px 16px rgba(61,107,82,0.45);
    }

    /* ══════════════════════════════════════════════════════════════
       08 — GALLERY
    ══════════════════════════════════════════════════════════════ */
    .gallery { background: var(--color-canvas); padding: var(--section-py) 0; }
    .gallery__tabs {
      display: flex;
      justify-content: center;
      gap: 8px;
      flex-wrap: wrap;
      margin-bottom: 32px;
    }
    .gallery__tab {
      padding: 8px 20px;
      border-radius: var(--rounded-full);
      font-family: var(--font-body);
      font-size: 14px;
      font-weight: 500;
      cursor: pointer;
      border: 1.5px solid var(--color-hairline);
      background: #fff;
      color: var(--color-body);
      transition: all 0.15s ease;
    }
    .gallery__tab.active,
    .gallery__tab:hover {
      background: var(--color-ink);
      color: #fff;
      border-color: var(--color-ink);
    }
    .gallery__grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      grid-auto-rows: 260px;
      gap: 12px;
    }
    .gallery__item {
      border-radius: var(--rounded-sm);
      overflow: hidden;
      position: relative;
      cursor: pointer;
    }
    .gallery__item img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      transition: transform 0.4s ease;
    }
    .gallery__item:hover img { transform: scale(1.05); }
    .gallery__item--tall { grid-row: span 2; }
    .gallery__caption {
      position: absolute;
      bottom: 0;
      left: 0;
      right: 0;
      padding: 14px;
      background: linear-gradient(to top, rgba(0,0,0,0.72), transparent);
      font-size: 12px;
      font-weight: 600;
      color: rgba(255,255,255,0.92);
      opacity: 0;
      transition: opacity 0.22s ease;
    }
    .gallery__item:hover .gallery__caption { opacity: 1; }

    /* ══════════════════════════════════════════════════════════════
       09 — PRICING
    ══════════════════════════════════════════════════════════════ */
    .pricing { background: var(--color-warm-cream); padding: var(--section-py) 0; }
    .pricing__promo-banner {
      display: flex;
      justify-content: center;
      margin-bottom: 44px;
    }
    .pricing__promo {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 10px 22px;
      background: var(--color-accent-light);
      border: 1.5px solid var(--color-accent);
      border-radius: var(--rounded-full);
      font-size: 14px;
      font-weight: 600;
      color: var(--color-accent);
    }
    .pricing__grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 20px;
      align-items: start;
    }
    .pricing-card {
      padding: 28px;
      border: 1.5px solid var(--color-hairline);
      border-radius: var(--rounded-md);
      background: var(--color-canvas);
    }
    .pricing-card--featured {
      border-color: var(--color-primary);
      box-shadow: 0 0 0 1px var(--color-primary), var(--shadow-card);
      transform: scale(1.025);
    }
    .pricing-card__icon { font-size: 32px; margin-bottom: 16px; }
    .pricing-card__label {
      font-size: 11px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: var(--color-primary);
      margin-bottom: 8px;
    }
    .pricing-card__title {
      font-size: 22px;
      font-weight: 700;
      color: var(--color-ink);
      margin-bottom: 20px;
    }
    .pricing-card__items {
      display: flex;
      flex-direction: column;
      gap: 11px;
      margin-bottom: 26px;
    }
    .pricing-card__items li {
      display: flex;
      align-items: flex-start;
      gap: 9px;
      font-size: 14px;
      color: var(--color-body);
      line-height: 1.45;
    }
    .pricing-card__items li::before {
      content: '✓';
      font-size: 12px;
      font-weight: 700;
      color: var(--color-primary);
      flex-shrink: 0;
      margin-top: 2px;
    }

    /* ══════════════════════════════════════════════════════════════
       10 — DEVELOPER
    ══════════════════════════════════════════════════════════════ */
    .developer { background: var(--color-dark-band); padding: var(--section-py) 0; }
    .developer__inner {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 80px;
      align-items: center;
    }
    .developer__text .section-label { color: rgba(255,255,255,0.5); }
    .developer__text h2 {
      font-family: var(--font-display);
      font-size: clamp(28px, 3vw, 42px);
      font-weight: 400;
      color: #fff;
      margin-bottom: 18px;
      line-height: 1.18;
    }
    .developer__text p {
      font-size: 16px;
      line-height: 1.8;
      color: rgba(255,255,255,0.68);
      margin-bottom: 28px;
    }
    .developer__certs { display: flex; gap: 10px; flex-wrap: wrap; }
    .developer__cert {
      padding: 7px 15px;
      background: rgba(255,255,255,0.08);
      border: 1px solid rgba(255,255,255,0.14);
      border-radius: var(--rounded-full);
      font-size: 13px;
      color: rgba(255,255,255,0.78);
      font-weight: 500;
    }
    .developer__stats {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 40px 48px;
    }
    .developer__stat-num {
      font-family: var(--font-display);
      font-size: 56px;
      font-weight: 400;
      color: #fff;
      line-height: 1;
      margin-bottom: 6px;
    }
    .developer__stat-label { font-size: 14px; color: rgba(255,255,255,0.55); font-weight: 500; }

    /* ══════════════════════════════════════════════════════════════
       11 — TESTIMONIALS
    ══════════════════════════════════════════════════════════════ */
    .testimonials { background: var(--color-canvas); padding: var(--section-py) 0; }
    .testimonials__grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 20px;
    }
    .testimonial-card {
      padding: 28px;
      border: 1px solid var(--color-hairline);
      border-radius: var(--rounded-md);
      background: var(--color-canvas);
      transition: box-shadow 0.25s ease;
    }
    .testimonial-card:hover { box-shadow: var(--shadow-card-hover); }
    .testimonial-card__quote {
      font-family: var(--font-display);
      font-size: 40px;
      line-height: 1;
      color: var(--color-primary-light);
      margin-bottom: 12px;
    }
    .testimonial-card__text {
      font-size: 15px;
      line-height: 1.72;
      color: var(--color-body);
      margin-bottom: 22px;
    }
    .testimonial-card__author { display: flex; align-items: center; gap: 12px; }
    .testimonial-card__avatar {
      width: 44px;
      height: 44px;
      border-radius: var(--rounded-full);
      overflow: hidden;
      flex-shrink: 0;
    }
    .testimonial-card__avatar img { width: 100%; height: 100%; object-fit: cover; }
    .testimonial-card__name { font-size: 14px; font-weight: 700; color: var(--color-ink); }
    .testimonial-card__role { font-size: 13px; color: var(--color-muted); margin-top: 1px; }
    .testimonial-card__stars { font-size: 12px; color: var(--color-ink); margin-top: 3px; }

    /* ══════════════════════════════════════════════════════════════
       12 — FAQ
    ══════════════════════════════════════════════════════════════ */
    .faq { background: var(--color-warm-cream); padding: var(--section-py) 0; }
    .faq__inner { max-width: 740px; margin: 0 auto; }
    .faq__items { border-top: 1px solid var(--color-hairline); }
    .faq__item { border-bottom: 1px solid var(--color-hairline); }
    .faq__question {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 20px 0;
      cursor: pointer;
      gap: 16px;
      user-select: none;
    }
    .faq__question-text { font-size: 16px; font-weight: 600; color: var(--color-ink); }
    .faq__chevron {
      font-size: 20px;
      color: var(--color-muted);
      flex-shrink: 0;
      transition: transform 0.25s ease;
      line-height: 1;
    }
    .faq__answer {
      display: grid;
      grid-template-rows: 0fr;
      transition: grid-template-rows 0.3s ease;
    }
    .faq__answer-inner { overflow: hidden; }
    .faq__answer p {
      font-size: 15px;
      line-height: 1.72;
      color: var(--color-body);
      padding-bottom: 20px;
    }
    .faq__item.open .faq__chevron { transform: rotate(180deg); }
    .faq__item.open .faq__answer { grid-template-rows: 1fr; }

    /* ══════════════════════════════════════════════════════════════
       13 — BOOKING CTA
    ══════════════════════════════════════════════════════════════ */
    .booking { background: var(--color-primary); padding: var(--section-py) 0; }
    .booking__inner {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 72px;
      align-items: center;
    }
    .booking__text h2 {
      font-family: var(--font-display);
      font-size: clamp(30px, 3.2vw, 46px);
      font-weight: 400;
      color: #fff;
      line-height: 1.15;
      margin-bottom: 18px;
    }
    .booking__text p {
      font-size: 16px;
      line-height: 1.72;
      color: rgba(255,255,255,0.78);
    }
    .booking__form {
      background: #fff;
      border-radius: var(--rounded-lg);
      padding: 36px;
    }
    .booking__form-title {
      font-size: 18px;
      font-weight: 700;
      color: var(--color-ink);
      margin-bottom: 24px;
    }
    .form__row {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 16px;
    }
    .form__group {
      display: flex;
      flex-direction: column;
      gap: 6px;
      margin-bottom: 16px;
    }
    .form__group label {
      font-size: 12px;
      font-weight: 700;
      color: var(--color-ink);
      letter-spacing: 0.02em;
    }
    .form__group input,
    .form__group select {
      padding: 12px 14px;
      border: 1.5px solid var(--color-hairline);
      border-radius: var(--rounded-sm);
      font-family: var(--font-body);
      font-size: 15px;
      color: var(--color-ink);
      background: var(--color-canvas);
      transition: border-color 0.15s ease;
      outline: none;
      appearance: none;
    }
    .form__group input:focus,
    .form__group select:focus { border-color: var(--color-primary); }
    .form__group input::placeholder { color: var(--color-muted); }

    /* ══════════════════════════════════════════════════════════════
       14 — FOOTER
    ══════════════════════════════════════════════════════════════ */
    .footer { background: var(--color-warm-cream); padding: 60px 0 0; }
    .footer__top {
      display: grid;
      grid-template-columns: 2fr 1fr 1fr 1fr;
      gap: 48px;
      padding-bottom: 48px;
      border-bottom: 1px solid var(--color-hairline);
    }
    .footer__brand-desc {
      font-size: 14px;
      color: var(--color-muted);
      line-height: 1.65;
      margin-top: 14px;
      margin-bottom: 22px;
    }
    .footer__address {
      font-size: 13px;
      color: var(--color-muted);
      line-height: 1.6;
      margin-bottom: 20px;
    }
    .footer__socials { display: flex; gap: 10px; }
    .footer__social {
      width: 36px;
      height: 36px;
      background: var(--color-surface-soft);
      border-radius: var(--rounded-full);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 15px;
      transition: background 0.15s ease;
    }
    .footer__social:hover { background: var(--color-primary-light); }
    .footer__col-title {
      font-size: 13px;
      font-weight: 700;
      color: var(--color-ink);
      margin-bottom: 16px;
      letter-spacing: 0.02em;
    }
    .footer__col-links {
      display: flex;
      flex-direction: column;
      gap: 10px;
    }
    .footer__col-links a {
      font-size: 14px;
      color: var(--color-muted);
      transition: color 0.15s ease;
    }
    .footer__col-links a:hover { color: var(--color-ink); }
    .footer__bottom {
      padding: 22px 0;
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 16px;
    }
    .footer__legal { font-size: 13px; color: var(--color-muted); }
    .footer__tagline {
      font-family: var(--font-display);
      font-size: 14px;
      font-style: italic;
      color: var(--color-muted);
    }

    /* ──────────────────────────────────────────────────────────────
       RESPONSIVE
    ────────────────────────────────────────────────────────────── */
    @media (max-width: 1100px) {
      :root { --container-px: 48px; }
      .types__grid { grid-template-columns: repeat(2, 1fr); }
      .footer__top { grid-template-columns: 1fr 1fr; }
    }

    @media (max-width: 768px) {
      :root { --container-px: 24px; --section-py: 60px; }
      .navbar__links { display: none; }
      .about__grid { grid-template-columns: 1fr; gap: 36px; }
      .about__photo { aspect-ratio: 16/9; }
      .types__grid { grid-template-columns: 1fr; }
      .masterplan__visual { aspect-ratio: 4/3; }
      .facilities__grid { grid-template-columns: 1fr; }
      .location__grid { grid-template-columns: 1fr; gap: 40px; }
      .gallery__grid {
        grid-template-columns: 1fr 1fr;
        grid-auto-rows: 200px;
      }
      .gallery__item--tall { grid-row: auto; }
      .pricing__grid { grid-template-columns: 1fr; }
      .pricing-card--featured { transform: none; }
      .developer__inner { grid-template-columns: 1fr; gap: 48px; }
      .testimonials__grid { grid-template-columns: 1fr; }
      .booking__inner { grid-template-columns: 1fr; gap: 40px; }
      .form__row { grid-template-columns: 1fr; }
      .footer__top { grid-template-columns: 1fr 1fr; gap: 32px; }
      .footer__bottom { flex-direction: column; align-items: flex-start; }
    }
  </style>
</head>

