  <script>
    // FAQ Accordion
    document.querySelectorAll('.faq__question').forEach(q => {
      q.addEventListener('click', () => {
        const item = q.parentElement;
        const isOpen = item.classList.contains('open');
        document.querySelectorAll('.faq__item').forEach(i => i.classList.remove('open'));
        if (!isOpen) item.classList.add('open');
      });
    });

    // Gallery tab (visual only — full filter needs data-cat matching logic)
    document.querySelectorAll('.gallery__tab').forEach(tab => {
      tab.addEventListener('click', () => {
        document.querySelectorAll('.gallery__tab').forEach(t => t.classList.remove('active'));
        tab.classList.add('active');
      });
    });

    // Smooth navbar shrink on scroll
    const navbar = document.querySelector('.navbar');
    window.addEventListener('scroll', () => {
      navbar.style.boxShadow = window.scrollY > 20
        ? '0 2px 12px rgba(0,0,0,0.08)'
        : 'none';
    }, { passive: true });
  </script>

