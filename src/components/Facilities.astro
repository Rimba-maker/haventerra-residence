---
import FacilityCard from './FacilityCard.astro';
import {
  Waves,
  Ruler,
  Building2,
  Gamepad2,
  ShoppingCart,
  ShieldCheck,
} from '@lucide/astro';

const facilities = [
  {
    title: 'Olympic-Size Pool',
    desc: 'Untuk dewasa & anak-anak, lengkap dengan kabana dan area berjemur yang nyaman.',
    image:
      'https://images.unsplash.com/photo-1575429198097-0414ec08e8cd?auto=format&fit=crop&w=700&q=80',
    icon: Waves,
  },
  {
    title: '1,2 KM Jogging Track',
    desc: 'Mengelilingi seluruh kawasan dengan view rindang yang menyegarkan di setiap pagi.',
    image:
      'https://images.unsplash.com/photo-1571902943202-507ec2618e8f?auto=format&fit=crop&w=700&q=80',
    icon: Ruler,
  },
  {
    title: 'Clubhouse Modern',
    desc: 'Gym, ruang serbaguna, dan co-working space. Produktif tanpa harus keluar kawasan.',
    image:
      'https://images.unsplash.com/photo-1497366216548-37526070297c?auto=format&fit=crop&w=700&q=80',
    icon: Building2,
  },
  {
    title: 'Children Playground',
    desc: '3 zona berbeda untuk toddler, kids, dan teens. Aman, seru, dan desain yang menstimulasi.',
    image:
      'https://images.unsplash.com/photo-1594736797933-d0501ba2fe65?auto=format&fit=crop&w=700&q=80',
    icon: Gamepad2,
  },
  {
    title: 'Commercial Area',
    desc: 'Minimarket, cafe, laundry, dan klinik — semua kebutuhan sehari-hari dalam satu kawasan.',
    image:
      'https://images.unsplash.com/photo-1445116572660-236099ec97a0?auto=format&fit=crop&w=700&q=80',
    icon: ShoppingCart,
  },
  {
    title: '24/7 Security & CCTV',
    desc: 'One-gate system dengan akses RFID dan monitoring CCTV yang aktif sepanjang hari.',
    image:
      'https://images.unsplash.com/photo-1558618666-fcd25c85cd64?auto=format&fit=crop&w=700&q=80',
    icon: ShieldCheck,
  },
];
---

<section class="facilities" id="fasilitas">
  <div class="container">
    <div class="section-header">
      <span class="section-label">Fasilitas</span>
      <h2>Fasilitas Yang Bikin Betah</h2>
      <p>Semua yang kamu butuhkan, ada di dalam kawasan.</p>
    </div>
    <div class="facilities__grid">
      {
        facilities.map((f) => (
          <FacilityCard
            title={f.title}
            desc={f.desc}
            image={f.image}
            iconName=""
          >
            <f.icon slot="icon" size={26} />
          </FacilityCard>
        ))
      }
    </div>
  </div>
</section>

<style>
  .facilities {
    background: var(--color-canvas);
    padding: var(--section-py) 0;
  }
  .facilities__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }

  @media (max-width: 768px) {
    .facilities__grid {
      grid-template-columns: 1fr;
    }
  }
</style>
