---
interface Props {
  name: string;
  specs: string;
  price: string;
  units: string;
  image: string;
  badge?: string;
}

const { name, specs, price, units, image, badge } = Astro.props;
---

<div class="type-card">
  <div class="type-card__photo">
    <img src={image} alt={`${name} — ${specs}`} />
    {badge && <span class="type-card__badge">{badge}</span>}
    <button class="type-card__save" aria-label={`Simpan ${name}`}>🤍</button>
  </div>
  <div class="type-card__meta">
    <div class="type-card__name">{name}</div>
    <div class="type-card__specs" set:html={specs} />
    <div class="type-card__price">
      {price}
      <span class="type-card__price-note">/ unit</span>
    </div>
    <div class="type-card__units">✓ {units} tersedia</div>
  </div>
</div>

<style>
  .type-card {
    background: var(--color-canvas);
    border-radius: var(--rounded-md);
    overflow: hidden;
    box-shadow: var(--shadow-card);
    transition:
      box-shadow 0.3s ease,
      transform 0.3s ease;
    cursor: pointer;
  }
  .type-card:hover {
    box-shadow: var(--shadow-card-hover);
    transform: translateY(-7px);
  }
  .type-card__photo {
    position: relative;
    aspect-ratio: 4 / 5;
    overflow: hidden;
  }
  .type-card__photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }
  .type-card:hover .type-card__photo img {
    transform: scale(1.05);
  }
  .type-card__badge {
    position: absolute;
    top: 12px;
    left: 12px;
    padding: 5px 11px;
    background: var(--color-accent);
    color: #fff;
    border-radius: var(--rounded-full);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.02em;
  }
  .type-card__save {
    position: absolute;
    top: 10px;
    right: 10px;
    width: 32px;
    height: 32px;
    background: rgba(255, 255, 255, 0.88);
    border-radius: var(--rounded-full);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 15px;
    cursor: pointer;
    border: none;
    transition:
      transform 0.15s ease,
      background 0.15s ease;
  }
  .type-card__save:hover {
    transform: scale(1.12);
    background: #fff;
  }
  .type-card__meta {
    padding: 16px;
  }
  .type-card__name {
    font-size: 15px;
    font-weight: 600;
    color: var(--color-ink);
    margin-bottom: 5px;
  }
  .type-card__specs {
    font-size: 13px;
    color: var(--color-muted);
    line-height: 1.55;
    margin-bottom: 10px;
  }
  .type-card__price {
    font-size: 16px;
    font-weight: 700;
    color: var(--color-ink);
  }
  .type-card__price-note {
    font-size: 12px;
    font-weight: 400;
    color: var(--color-muted);
  }
  .type-card__units {
    font-size: 12px;
    color: var(--color-primary);
    font-weight: 600;
    margin-top: 4px;
  }
</style>
