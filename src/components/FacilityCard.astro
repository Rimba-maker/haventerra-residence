---
import type { LucideIcon } from '@lucide/astro';

interface Props {
  title: string;
  desc: string;
  image: string;
  iconName: string;
}

const { title, desc, image, iconName } = Astro.props;

// Dynamically import icons if needed, but for now we'll pass the icon component name or just use a switch in the parent.
// To keep it simple, we'll use a slot for the icon.
---

<div class="facility-card">
  <div class="facility-card__photo">
    <img src={image} alt={title} />
  </div>
  <div class="facility-card__meta">
    <div class="facility-card__icon">
      <slot name="icon" />
    </div>
    <div class="facility-card__title">{title}</div>
    <div class="facility-card__desc">{desc}</div>
  </div>
</div>

<style>
  .facility-card {
    background: var(--color-canvas);
    border-radius: var(--rounded-md);
    overflow: hidden;
    box-shadow: var(--shadow-card);
    transition:
      transform 0.25s ease,
      box-shadow 0.25s ease;
  }
  .facility-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-card-hover);
  }
  .facility-card__photo {
    aspect-ratio: 16 / 9;
    overflow: hidden;
  }
  .facility-card__photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.45s ease;
  }
  .facility-card:hover .facility-card__photo img {
    transform: scale(1.05);
  }
  .facility-card__meta {
    padding: 20px;
  }
  .facility-card__icon {
    font-size: 26px;
    margin-bottom: 10px;
    color: var(--color-primary);
  }
  .facility-card__title {
    font-size: 16px;
    font-weight: 700;
    color: var(--color-ink);
    margin-bottom: 6px;
  }
  .facility-card__desc {
    font-size: 14px;
    color: var(--color-muted);
    line-height: 1.55;
  }
</style>
