---
import {
  Train,
  Road,
  School,
  Hospital,
  ShoppingBag,
  Plane,
} from '@lucide/astro';

const landmarks = [
  { icon: Train, name: 'Stasiun Rawa Buntu (KRL)', dist: '5 menit' },
  { icon: Road, name: 'Tol Serpong–Pondok Aren', dist: '8 menit' },
  { icon: School, name: 'Sekolah BSD & Ora et Labora', dist: '10 menit' },
  { icon: Hospital, name: 'RS Eka Hospital BSD', dist: '12 menit' },
  { icon: ShoppingBag, name: 'AEON Mall & ICE BSD', dist: '15 menit' },
  { icon: Plane, name: 'Bandara Soekarno-Hatta', dist: '35 menit' },
];
---

<section class="location" id="lokasi">
  <div class="container">
    <div class="location__grid">
      <div class="location__text">
        <span class="section-label">Lokasi</span>
        <h2>Strategis,<br />Akses Mudah</h2>
        <p>
          Berada di jantung Tangerang Selatan, Haventerra menghubungkan kamu ke
          seluruh penjuru kota dengan mudah.
        </p>
        <div class="location__landmarks">
          {
            landmarks.map((l) => (
              <div class="location__landmark">
                <span class="location__landmark-icon">
                  <l.icon size={18} />
                </span>
                <span class="location__landmark-name">{l.name}</span>
                <span class="location__landmark-dist">{l.dist}</span>
              </div>
            ))
          }
        </div>
      </div>

      <div class="location__map">
        <img
          src="https://images.unsplash.com/photo-1524661135-423995f22d0b?auto=format&fit=crop&w=800&q=80"
          alt="Peta lokasi Haventerra Residence Tangerang Selatan"
        />
        <div class="location__map-pin">📍 Haventerra Residence</div>
      </div>
    </div>
  </div>
</section>

<style>
  .location {
    background: var(--color-warm-cream);
    padding: var(--section-py) 0;
  }
  .location__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 72px;
    align-items: center;
  }
  .location__text h2 {
    font-family: var(--font-display);
    font-size: clamp(28px, 3vw, 42px);
    font-weight: 400;
    color: var(--color-ink);
    margin-bottom: 12px;
  }
  .location__text > p {
    font-size: 16px;
    color: var(--color-muted);
    margin-bottom: 32px;
    line-height: 1.65;
  }
  .location__landmarks {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .location__landmark {
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 13px 16px;
    background: #fff;
    border-radius: var(--rounded-sm);
    border: 1px solid var(--color-hairline);
    transition:
      border-color 0.15s ease,
      background 0.15s ease;
  }
  .location__landmark:hover {
    border-color: var(--color-primary-light);
    background: rgba(212, 232, 219, 0.25);
  }
  .location__landmark-icon {
    font-size: 18px;
    flex-shrink: 0;
    color: var(--color-primary);
  }
  .location__landmark-name {
    font-size: 14px;
    font-weight: 500;
    color: var(--color-ink);
    flex: 1;
  }
  .location__landmark-dist {
    font-size: 13px;
    font-weight: 700;
    color: var(--color-primary);
    flex-shrink: 0;
  }
  .location__map {
    border-radius: var(--rounded-lg);
    overflow: hidden;
    aspect-ratio: 1 / 1;
    position: relative;
  }
  .location__map img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .location__map-pin {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    background: var(--color-primary);
    color: #fff;
    padding: 9px 18px;
    border-radius: var(--rounded-full);
    font-size: 13px;
    font-weight: 700;
    white-space: nowrap;
    box-shadow: 0 4px 16px rgba(61, 107, 82, 0.45);
  }

  @media (max-width: 768px) {
    .location__grid {
      grid-template-columns: 1fr;
      gap: 40px;
    }
  }
</style>
